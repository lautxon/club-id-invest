# Club ID Invest - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Club ID Invest
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/club_id_invest
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# SECURITY - CHANGE THESE IN PRODUCTION!
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_AUDIENCE=club-id-invest
JWT_ISSUER=club-id-invest-api

# =============================================================================
# CORS ORIGINS (comma-separated)
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# =============================================================================
# REDIS & CELERY
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# TASK SCHEDULING (in seconds)
# =============================================================================
AUTO_INVESTMENT_CHECK_INTERVAL=86400
MEMBERSHIP_LIFECYCLE_CHECK_INTERVAL=86400

# =============================================================================
# CONTRACT GENERATION
# =============================================================================
CONTRACT_TEMPLATE_PATH=templates/contracts
CONTRACT_OUTPUT_PATH=generated_contracts

# =============================================================================
# AUDIT LOGGING
# =============================================================================
AUDIT_LOG_RETENTION_DAYS=2555
